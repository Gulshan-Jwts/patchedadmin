<!DOCTYPE html>
<html lang="en">

<head>
  <title>Admin dashboard</title>
  <link rel="stylesheet" href="../globals.css" />

  <style>
    :root {
      --admin-bg: #fdfdfd;
      --border-light: #eff1f3;
    }

    body {
      background-color: var(--admin-bg);
      padding-bottom: 40px;
      user-select: text !important;
    }

    .admin-navbar {
      height: 64px;
      background: var(--surface);
      border-bottom: 1px solid #dadce0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 24px;
      position: sticky;
      top: 0;
      z-index: 2000;
    }

    .nav-left {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .nav-logo-icon {
      color: var(--accent-blue);
      font-size: 28px;
    }

    .nav-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--text-main);
    }

    .nav-right {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .btn-logout {
      color: #d93025;
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 8px 16px;
      border-radius: var(--radius-pill);
      transition: var(--transition);
    }

    .btn-logout:active {
      background: #ffeeec;
      transform: scale(0.98);
    }

    .dashboard-main {
      max-width: 1200px;
      margin: 24px auto;
      padding: 0 20px;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 16px;
      margin-bottom: 32px;
    }

    .stat-card {
      background: var(--surface);
      padding: 20px;
      border-radius: var(--radius-m);
      border: 1px solid var(--border-light);
      box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
      transition: var(--transition);
    }

    .stat-card:active {
      transform: scale(0.99);
    }

    .stat-label {
      font-size: 0.7rem;
      color: var(--text-sub);
      font-weight: 700;
      text-transform: uppercase;
      margin-bottom: 8px;
      letter-spacing: 0.5px;
    }

    .stat-val {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--text-main);
    }

    .stat-subtext {
      font-size: 0.8rem;
      color: var(--accent-blue);
      font-weight: 500;
      margin-top: 4px;
    }

    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 16px;
    }

    .btn-navigate {
      background: var(--accent-blue-container);
      color: var(--md-on-blue-container);
      padding: 10px 18px;
      border-radius: var(--radius-pill);
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      gap: 6px;
      transition: var(--transition);
    }

    .btn-navigate:active {
      transform: scale(0.98);
      filter: contrast(1.1);
    }

    @media (max-width: 500px) {
      .stats-grid {
        grid-template-columns: 1fr;
      }

      .table-row {
        grid-template-columns: 1fr;
      }

      .user-cell {
        grid-column: span 1;
      }
    }
  </style>
</head>

<body>
  <nav class="admin-navbar">
    <div class="nav-left">
      <span class="material-symbols-rounded nav-logo-icon">dashboard</span>
      <span class="nav-title">CarriagePatch Admin</span>
    </div>
    <div class="nav-right">
      <a href="/logout" class="btn-logout">
        <span class="material-symbols-rounded" style="font-size: 20px">logout</span>
        Logout
      </a>
    </div>
  </nav>

  <main class="dashboard-main">
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-label">Total Users</div>
        <div class="stat-val"><%= totalUsers %></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Inactive Users</div>
        <div class="stat-val"><%= inactiveUsers %></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Free Users</div>
        <div class="stat-val"><%= freeUsers %></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">₹199 Users</div>
        <div class="stat-val"><%= firstUsers %></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">₹299 Users</div>
        <div class="stat-val"><%= secondUsers %></div>
      </div>
    </div>

    <div class="section-header">
      <a href="/topay" class="btn-navigate">
        To Pay
        <span class="material-symbols-rounded">chevron_right</span>
      </a>
      <a href="/toconfirm" class="btn-navigate">
        To Activate
        <span class="material-symbols-rounded">chevron_right</span>
      </a>
    </div>
  </main>
</body>

</html>