<!DOCTYPE html>
<html>
  <head>
    <title>Login</title>
    <style>
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
        font-family:
          Segoe UI,
          Segoe UI Midlevel,
          Segoe WP,
          Arial,
          sans-serif;
        -webkit-tap-highlight-color: transparent;
      }

      body {
        padding: 6px;
        background-color: #292929;
        width: 100vw;
        height: 100%;
      }

      .frame {
        height: calc(100dvh - 12px);
        width: calc(100vw - 12px);
        background-image: url("data:text/html;charset=utf-8;base64,");
        padding-top: 10vh;
        background-size: cover;
        border-radius: 10px;
      }

      img {
        margin: 10px 0;
      }

      h2 {
        font-family:
          "Segoe UI Variable",
          "Segoe Sans",
          "Segoe UI",
          "Segoe UI Web (West European)",
          -apple-system,
          BlinkMacSystemFont,
          Roboto,
          "Helvetica Neue",
          sans-serif;
        font-size: 20px;
        font-weight: 600;
        color: #fff;
        text-align: center;
        margin-top: -25px;
      }

      form {
        display: flex;
        flex-direction: column;
        max-width: 80vw;
        align-items: center;
        margin: 0 auto;
        gap: 15px;
        border-radius: 8px;
        background-color: #333333;
        box-shadow:
          0 0 2px rgba(0, 0, 0, 0.24),
          0 1px 2px rgba(0, 0, 0, 0.28);
        padding: 10px;
        margin-top: 30px;
      }

      input {
        width: 100%;
        height: 100%;
        box-sizing: border-box;
        color: #fff;
        border-radius: calc(4px * 1.8);
        corner-shape: squircle;
        background: #ffffff00;
        font-family:
          "Segoe UI Variable",
          "Segoe Sans",
          "Segoe UI",
          "Segoe UI Web (West European)",
          -apple-system,
          BlinkMacSystemFont,
          Roboto,
          "Helvetica Neue",
          sans-serif;
        font-weight: 400;
        font-size: 14px;
        border: 1px solid #ffffff47;
        vertical-align: center;
        padding: 6px 5px;
        outline: none;
        background-color: #ffffff14;
      }

      button {
        background-color: #29292980;
        border: 1px solid #ffffff47;
        color: #fff;
        padding: 5px 10px;
        border-radius: calc(4px * 1.8);
        font-size: 15px;
        display: flex;
        align-items: center;
        gap: 8px;
      }
    </style>
  </head>
  <body>
    <div class="frame">
      <form action="/login" method="POST">
        <img
          aria-hidden="true"
          class="image-icon"
          src="data:image/png;base64," />
        <h2>Login</h2>
        <input type="email" name="email" placeholder="Email" required />
        <input
          type="password"
          name="password"
          placeholder="Password"
          required />
        <button type="submit">
          Login
          <svg
            width="20px"
            height="20px"
            viewBox="0 0 20 20"
            fill="currentColor">
            <path
              d="M6 4C4.89543 4 4 4.89543 4 6V14C4 15.1046 4.89543 16 6 16H14C15.1046 16 16 15.1046 16 14V11.5C16 11.2239 16.2239 11 16.5 11C16.7761 11 17 11.2239 17 11.5V14C17 15.6569 15.6569 17 14 17H6C4.34315 17 3 15.6569 3 14V6C3 4.34315 4.34315 3 6 3H8.5C8.77614 3 9 3.22386 9 3.5C9 3.77614 8.77614 4 8.5 4H6ZM11 3.5C11 3.22386 11.2239 3 11.5 3H16.5C16.7761 3 17 3.22386 17 3.5V8.5C17 8.77614 16.7761 9 16.5 9C16.2239 9 16 8.77614 16 8.5V4.70711L11.8536 8.85355C11.6583 9.04882 11.3417 9.04882 11.1464 8.85355C10.9512 8.65829 10.9512 8.34171 11.1464 8.14645L15.2929 4H11.5C11.2239 4 11 3.77614 11 3.5Z"
              fillrule="nonzero"></path>
          </svg>
        </button>
      </form>
    </div>
  </body>
</html>
