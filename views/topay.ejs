<!DOCTYPE html>
<html lang="en">

<head>
  <title>to pay</title>
  <link rel="stylesheet" href="../globals.css" />

  <style>
    :root {
      --admin-bg: #f8f9fa;
      --border-light: #eff1f3;
    }

    body {
      background-color: var(--admin-bg);
      padding-bottom: 40px;
      user-select: text !important;
    }

    .admin-navbar {
      height: 64px;
      background: var(--surface);
      border-bottom: 1px solid #dadce0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 24px;
      position: sticky;
      top: 0;
      z-index: 2000;
    }

    .nav-left {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .nav-logo-icon {
      color: var(--accent-blue);
      font-size: 28px;
    }

    .nav-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--text-main);
    }

    .btn-back {
      color: var(--text-sub);
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 8px 16px;
      border-radius: var(--radius-pill);
      transition: var(--transition);
    }

    .btn-back:active {
      transform: scale(0.98);
      background: #f1f3f4;
      color: var(--text-main);
    }

    .dashboard-main {
      max-width: 1200px;
      margin: 24px auto;
      padding: 0 20px;
    }

    .stat-card {
      background: var(--surface);
      padding: 20px;
      border-radius: var(--radius-m);
      border: 1px solid var(--border-light);
      box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
      transition: var(--transition);
      margin-bottom: 18px;
    }

    .stat-card:active {
      transform: scale(0.99);
    }

    .stat-label {
      font-size: 0.7rem;
      color: var(--text-sub);
      font-weight: 700;
      text-transform: uppercase;
      margin-bottom: 8px;
      letter-spacing: 0.5px;
    }

    .stat-val {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--text-main);
    }

    .stat-subtext {
      font-size: 0.8rem;
      color: var(--accent-blue);
      font-weight: 500;
      margin-top: 4px;
    }

    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 16px;
    }

    .submit-btn {
      background: var(--accent-blue-container);
      color: var(--md-on-blue-container);
      padding: 10px 16px;
      border: none;
      border-radius: var(--radius-pill);
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      gap: 6px;
      transition: var(--transition);
      margin-bottom: 18px;
      margin-left: auto;
      margin-right: 0;
    }

    .submit-btn:active {
      transform: scale(0.98);
      filter: contrast(1.1);
    }

    .data-panel {
      background: var(--surface);
      border-radius: var(--radius-m);
      border: 1px solid var(--border-light);
      overflow: visible;
    }

    .table-head {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr 0.8fr;
      padding: 14px 24px;
      background: #f8f9fa;
      border-bottom: 1px solid var(--border-light);
      font-size: 0.75rem;
      font-weight: 700;
      color: var(--text-sub);
      text-transform: uppercase;
    }

    .table-row {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr 0.8fr;
      padding: 16px 24px;
      border-bottom: 1px solid var(--border-light);
      align-items: center;
      transition: background 0.2s;
    }

    .table-row:last-child {
      border-bottom: none;
    }

    .table-row:hover {
      background: #fcfcfc;
    }

    .user-cell {
      position: relative;
      display: flex;
      align-items: center;
      gap: 12px;
      cursor: help;
    }

    .u-avatar {
      width: 36px;
      height: 36px;
      border-radius: 10px;
      background: #e8f0fe;
      color: var(--accent-blue);
      display: grid;
      place-items: center;
      font-weight: 700;
    }

    .popover-details {
      position: absolute;
      top: 45px;
      left: 0;
      width: 260px;
      background: #ffffff;
      border: 1px solid #dadce0;
      border-radius: var(--radius-m);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
      padding: 16px;
      z-index: 2500;
      opacity: 0;
      pointer-events: none;
      transform: translateY(10px);
      transition: var(--transition);
    }

    .user-cell:hover .popover-details {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }

    .pop-row {
      margin-bottom: 10px;
    }

    .pop-row:last-child {
      margin-bottom: 0;
    }

    .pop-label {
      font-size: 0.65rem;
      color: var(--text-sub);
      font-weight: 700;
      text-transform: uppercase;
      display: block;
    }

    .pop-val {
      font-size: 0.85rem;
      color: var(--text-main);
      font-weight: 500;
    }

    .badge {
      font-size: 0.75rem;
      font-weight: 700;
      padding: 4px 10px;
      border-radius: 6px;
    }

    .badge-withdraw {
      background: #fde8e8;
      color: #c81e1e;
      border: 1px solid #c8a2a2;
    }

    .badge-refer {
      background: #fff8e1;
      color: #b8860b;
      border: 1px solid #ffe082;
    }

    .btn-done {
      background: var(--accent-blue);
      color: white;
      border: none;
      padding: 10px 20px;
      border-radius: var(--radius-pill);
      font-weight: 700;
      font-size: 0.85rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 8px;
      transition: var(--transition);
    }

    .btn-done .tick-icon {
      display: none;
      font-size: 18px;
    }

    .btn-done.completed {
      background: var(--green);
      color: white;
    }

    .btn-done.completed .tick-icon {
      display: inline-block;
    }

    .btn-done:active {
      transform: scale(0.98);
      opacity: 0.9;
    }

    @media (max-width: 900px) {
      .table-head {
        display: none;
      }

      .table-row {
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        padding: 20px;
        border-bottom: 6px solid var(--admin-bg);
      }

      .user-cell {
        grid-column: span 2;
        border-bottom: 1px solid var(--border-light);
        padding-bottom: 12px;
      }

      .popover-details {
        width: calc(100vw - 40px);
        left: 0;
        position: fixed;
        top: auto;
        bottom: 20px;
        left: 20px;
      }

      .mobile-only-label {
        display: block;
        font-size: 0.7rem;
        color: var(--text-sub);
        font-weight: 700;
        text-transform: uppercase;
        margin-bottom: 2px;
      }
    }

    @media (max-width: 500px) {
      .stats-grid {
        grid-template-columns: 1fr;
      }

      .table-row {
        grid-template-columns: 1fr;
      }

      .user-cell {
        grid-column: span 1;
      }
    }
  </style>
</head>

<body>
  <nav class="admin-navbar">
    <div class="nav-left">
      <span class="material-symbols-rounded nav-logo-icon">dashboard</span>
      <span class="nav-title">CarriagePatch Admin</span>
    </div>
    <div class="nav-right">
      <a href="/home" class="btn-back">
        <span class="material-symbols-rounded" style="font-size: 20px">arrow_back</span>
        Dashboard
      </a>
    </div>
  </nav>

  <main class="dashboard-main">
    <div class="stat-card" style="border-bottom: 3px solid #ea4335">
      <div class="stat-label">To Pay Requests</div>
      <div class="stat-val"><%= usersToPay.length %></div>
      <div class="stat-subtext">Total: ₹<span id="total-amt">0</span></div>
    </div>

    <button class="submit-btn" onclick="submitPayments()">
      Submit
      <span class="material-symbols-rounded">done</span>
    </button>

    <div class="data-panel">
      <div class="table-head">
        <span>Select</span>
        <span>Account</span>
        <span>Amount</span>
        <span>Type</span>
        <span>Date</span>
      </div>

      <% usersToPay.forEach(user => { %>
      <div class="table-row">

        <div>
          <input type="checkbox" onchange="toggleUser('<%= user._id %>')">
        </div>

        <div class="user-cell">
          <div class="u-avatar">
            <%= user.name?.[0] || "U" %>
          </div>
          <div style="font-weight: 600;">
            <%= user.name %>
          </div>
          <div style="margin-left: auto;">
            <%= user.receivingPhone %>
          </div>
        </div>

        <div style="font-weight: 700;">
          ₹<%= user.withdraw?.amount || 0 %>
        </div>

        <div>
          <span class="badge <%= user.withdraw?.source === 'refer' ? 'badge-refer' : 'badge-withdraw' %>">
            <%= user.withdraw?.source || "withdrawal" %>
          </span>
        </div>

        <div style="color: var(--text-sub); font-size: 0.85rem;">
          <%= new Date(user.updatedAt).toDateString() %>
        </div>

      </div>
      <% }) %>
    </div>
    <script>
      const users = <%- JSON.stringify(usersToPay) %>;
      let selectedUsers = new Set();

      function toggleUser(id, amount) {
        if (selectedUsers.has(id)) {
          selectedUsers.delete(id);
        } else {
          selectedUsers.add(id);
        }
        updateTotal();
      }

      function updateTotal() {
        let total = 0;

        users.forEach(u => {
          if (selectedUsers.has(u._id)) {
            console.log(u.withdraw.amount)
            total += u.withdraw.amount || 0;
          }
        });

        console.log(total)

        document.getElementById("total-amt").innerText = total;
      }

      async function submitPayments() {
        if (selectedUsers.size === 0) {
          alert("Select users first");
          return;
        }

        const btn = document.querySelector(".submit-btn");
        btn.innerText = "Processing...";
        btn.disabled = true;

        console.log({
          userIds: Array.from(selectedUsers)
        });

        const res = await fetch("/user/pay", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            userIds: Array.from(selectedUsers)
          }),
        });

        const data = await res.json();

        if (data.success) {
          alert("Payments successful");
          location.reload();
        } else {
          alert(data.message);
        }

        btn.innerText = "Submit";
        btn.disabled = false;
      }
    </script>
  </main>
</body>

</html>